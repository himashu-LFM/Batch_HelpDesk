generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CaseType {
  INTERNAL
  PATIENT
}

enum CaseStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  ESCALATED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum PatientIssueType {
  PATIENT_CARE
  FOOD
  MAINTENANCE
}

model User {
  id             String              @id @default(uuid())
  email          String              @unique
  passwordHash   String?
  firstName      String
  lastName       String?
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  roles          UserRole[]
  ownedCases     Case[]              @relation("CaseOwner")
  createdCases   Case[]              @relation("CaseCreator")
  assignments    AssignmentHistory[] @relation("AssignedBy")
  notifications  NotificationLog[]   @relation("NotificationRecipient")
  auditEntries   AuditLog[]          @relation("AuditActor")
}

model Role {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  users     UserRole[]
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
}

model Queue {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cases     Case[]
}

model Case {
  id                   String              @id @default(uuid())
  caseNumber           String              @unique
  caseType             CaseType
  status               CaseStatus          @default(OPEN)
  queueId              String
  ownerId              String?
  createdByUserId      String?
  firstName            String
  lastName             String?
  email                String
  phone                String?
  employeeId           String?
  uhid                 String?
  subject              String
  description          String
  department           String?
  priority             Priority?
  patientIssueType     PatientIssueType?
  slaDueAt             DateTime?
  escalatedAt          DateTime?
  closedAt             DateTime?
  reopenedAt           DateTime?
  movedToInProgressAt  DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  queue                Queue               @relation(fields: [queueId], references: [id])
  owner                User?               @relation("CaseOwner", fields: [ownerId], references: [id])
  createdByUser        User?               @relation("CaseCreator", fields: [createdByUserId], references: [id])
  attachments          CaseAttachment[]
  events               CaseEvent[]
  assignmentHistory    AssignmentHistory[]
  notifications        NotificationLog[]
  auditEntries         AuditLog[]

  @@index([status, queueId])
  @@index([ownerId])
  @@index([createdByUserId])
  @@index([createdAt])
  @@index([email])
}

model CaseAttachment {
  id          String   @id @default(uuid())
  caseId      String
  fileName    String
  storageKey  String
  contentType String
  sizeBytes   Int
  uploadedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
}

model CaseEvent {
  id          String   @id @default(uuid())
  caseId      String
  eventType   String
  eventLabel  String
  metadataJson String?
  createdAt   DateTime @default(now())
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
}

model AssignmentHistory {
  id              String   @id @default(uuid())
  caseId          String
  fromOwnerId     String?
  toOwnerId       String?
  assignedByUserId String?
  note            String?
  createdAt       DateTime @default(now())
  case            Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  assignedByUser  User?    @relation("AssignedBy", fields: [assignedByUserId], references: [id])

  @@index([caseId, createdAt])
}

model NotificationLog {
  id               String   @id @default(uuid())
  caseId           String
  recipientUserId  String?
  channel          String
  templateKey      String
  status           String
  providerMessageId String?
  metadataJson     String?
  createdAt        DateTime @default(now())
  case             Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  recipientUser    User?    @relation("NotificationRecipient", fields: [recipientUserId], references: [id])

  @@index([caseId, createdAt])
  @@index([templateKey, status])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  caseId      String?
  action      String
  entityType  String
  entityId    String
  metadataJson String?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id])
  case        Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([caseId, createdAt])
  @@index([actorUserId, createdAt])
}